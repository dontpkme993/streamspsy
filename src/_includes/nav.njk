<!-- ══════════════ NAV ══════════════ -->
<header class="site-header" role="banner">
  <div class="nav-inner">
    <a href="{{ '/' | url }}" class="nav-logo" aria-label="溪水邊首頁">
      溪水邊 <span>Stream Side</span>
    </a>
    <nav aria-label="主選單">
      <ul class="nav-links" role="list">
        <li><a href="{{ '/about/' | url }}"{% if activeNav == 'about' %} class="active"{% endif %}>關於</a></li>
        <li><a href="{{ '/articles/' | url }}"{% if activeNav == 'articles' %} class="active"{% endif %}>專欄</a></li>
        <li><a href="{{ '/media/' | url }}"{% if activeNav == 'media' %} class="active"{% endif %}>聲音</a></li>
