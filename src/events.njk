            <span class="placeholder-text">活動名稱三 Event Title 3 Placeholder</span>
          </h3>
          <p style="font-size:0.85rem;color:rgba(67,52,48,0.65);line-height:1.7;">
            <span class="placeholder-text">時間、地點、人數限制、費用等活動詳細資訊佔位符。Event details Placeholder.</span>
          </p>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:flex-start;">
          <a href="#" class="btn-outline" rel="noopener" style="white-space:nowrap;font-size:0.85rem;">報名連結</a>
          <span style="font-size:0.78rem;color:rgba(67,52,48,0.45);white-space:nowrap;">即將開放報名</span>
        </div>
      </article>
    {% endif %}

