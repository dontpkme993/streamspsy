<!-- ══════════════ UPCOMING EVENTS ══════════════ -->
<section class="py-section" aria-labelledby="upcoming-heading">
  <div class="content-max">
    <p style="font-size:0.8rem;letter-spacing:0.18em;color:var(--straw);margin-bottom:0.5rem;text-transform:uppercase;">Upcoming</p>
    <h2 class="section-title" id="upcoming-heading" style="margin-bottom:2.5rem;">即將到來</h2>

    {% if events.length %}
      {% for event in events %}
        <article class="event-upcoming" role="article">
          <div class="event-date-badge" aria-label="活動日期">
            <div class="month">{{ event.date | dateDisplay }}</div>
            <div class="day">{{ event.date.slice(8, 10) }}</div>
          </div>
          <div>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              {% for tag in event.tags %}
                <span class="tag">#{{ tag }}</span>
              {% endfor %}
            </div>
            <h3 style="font-size:1.1rem;color:var(--oak);margin-bottom:0.5rem;line-height:1.5;">{{ event.name }}</h3>
            <p style="font-size:0.85rem;color:rgba(67,52,48,0.65);line-height:1.7;">{{ event.description }}</p>
          </div>
          <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:flex-start;">
            {% if event.link %}
              <a href="{{ event.link }}" class="btn-primary" rel="noopener" style="white-space:nowrap;">立即報名</a>
            {% endif %}
            <span style="font-size:0.78rem;color:rgba(67,52,48,0.45);white-space:nowrap;">{{ event.status }}</span>
          </div>
        </article>
      {% endfor %}
    {% else %}
      <!-- Placeholder events shown when Notion is not connected -->
      <article class="event-upcoming" role="article">
        <div class="event-date-badge" aria-label="活動日期">
          <div class="month">APR</div>
          <div class="day">12</div>
        </div>
        <div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
            <span class="tag">#工作坊</span>
            <span class="tag">#親子</span>
          </div>
          <h3 style="font-size:1.1rem;color:var(--oak);margin-bottom:0.5rem;line-height:1.5;">
            <span class="placeholder-text">活動名稱一 Event Title 1 Placeholder</span>
          </h3>
          <p style="font-size:0.85rem;color:rgba(67,52,48,0.65);line-height:1.7;">
            <span class="placeholder-text">時間、地點、人數限制、費用等活動詳細資訊佔位符。Event details: time, location, capacity, fees Placeholder.</span>
          </p>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:flex-start;">
          <a href="#" class="btn-primary" rel="noopener" style="white-space:nowrap;">立即報名</a>
          <span style="font-size:0.78rem;color:rgba(67,52,48,0.45);white-space:nowrap;">剩餘名額：<span class="placeholder-text">X / XX</span></span>
        </div>
      </article>

      <article class="event-upcoming" role="article">
        <div class="event-date-badge" aria-label="活動日期">
          <div class="month">MAY</div>
          <div class="day">03</div>
        </div>
        <div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
            <span class="tag">#個人諮商</span>
            <span class="tag">#線上</span>
          </div>
          <h3 style="font-size:1.1rem;color:var(--oak);margin-bottom:0.5rem;line-height:1.5;">
            <span class="placeholder-text">活動名稱二 Event Title 2 Placeholder</span>
          </h3>
          <p style="font-size:0.85rem;color:rgba(67,52,48,0.65);line-height:1.7;">
            <span class="placeholder-text">時間、地點、人數限制、費用等活動詳細資訊佔位符。Event details Placeholder.</span>
          </p>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:flex-start;">
          <a href="#" class="btn-primary" rel="noopener" style="white-space:nowrap;">立即報名</a>
          <span style="font-size:0.78rem;color:rgba(67,52,48,0.45);white-space:nowrap;">剩餘名額：<span class="placeholder-text">X / XX</span></span>
        </div>
      </article>

      <article class="event-upcoming" role="article">
        <div class="event-date-badge" aria-label="活動日期" style="background:var(--sprout);">
          <div class="month">JUN</div>
          <div class="day">21</div>
        </div>
        <div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
            <span class="tag">#演講</span>
            <span class="tag">#社區</span>
