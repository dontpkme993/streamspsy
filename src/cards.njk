    50%  { transform: translateX(8px) rotate(3deg); }
    75%  { transform: translateX(-4px) rotate(-1.5deg); }
    100% { transform: translateX(0) rotate(0deg); }
  }

  .shuffling .card-3d { animation: shuffle 0.5s ease; }

  /* Share toast */
  .toast {
