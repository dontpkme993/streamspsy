<!-- ══════════════ CARD STAGE ══════════════ -->
<section class="card-stage" aria-labelledby="card-heading">
  <h2 id="card-heading" style="position:absolute;opacity:0;pointer-events:none;">互動抽卡區</h2>

  <!-- 3D Card Flip -->
  <div class="card-3d-wrap" id="cardWrap" role="button" tabindex="0"
       aria-label="點擊翻牌" aria-pressed="false"
       onclick="flipCard()" onkeydown="if(event.key==='Enter'||event.key===' ')flipCard()">
    <div class="card-3d" id="card3d">

      <!-- Back face -->
      <div class="card-face card-back-face" aria-hidden="true">
        <div class="card-pattern">✦</div>
        <p>點擊翻牌</p>
      </div>

      <!-- Front face (shown when flipped) -->
      <div class="card-face card-front-face" id="cardFront">
        <p class="card-number" id="cardNumber">No. —</p>
        <div class="card-image-area" id="cardEmoji" aria-hidden="true">✨</div>
        <h3 id="cardTitle">
          <span class="placeholder-text">牌卡名稱 Card Name Placeholder</span>
        </h3>
        <p id="cardKeyword" style="font-size:0.78rem;color:var(--straw);font-weight:600;margin:0.2rem 0 0.4rem;">
          <span class="placeholder-text">關鍵詞 Keyword</span>
        </p>
      </div>

    </div>
  </div>

  <!-- ── Control Buttons ── -->
  <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-bottom:2.5rem;" role="group" aria-label="抽卡操作">
    <button class="btn-outline" id="shuffleBtn" onclick="shuffle()" aria-label="洗牌" style="font-size:0.85rem;padding:0.6rem 1.5rem;">
      🔀 洗牌
    </button>
    <button class="btn-primary" id="redrawBtn" onclick="redraw()" aria-label="重新抽卡" style="font-size:0.85rem;padding:0.6rem 1.5rem;">
      ✦ 重新抽卡
    </button>
    <button class="btn-outline" id="shareBtn" onclick="shareCard()" aria-label="分享牌卡" style="font-size:0.85rem;padding:0.6rem 1.5rem;">
      ↗ 分享
    </button>
  </div>

  <!-- ── Interpretation Area ── -->
  <div class="card-interpretation" id="interpretation" role="region" aria-live="polite" aria-label="牌卡解析">
    <div style="width:40px;height:2px;background:var(--straw);margin:0 auto 1.5rem;border-radius:2px;"></div>
    <h2 id="interpretTitle">
      <span class="placeholder-text">牌卡標題 Card Title Placeholder</span>
    </h2>
    <p id="interpretBody" style="margin-top:0.75rem;">
      <span class="placeholder-text">牌卡解析文字佔位符：每一張牌卡都有其獨特的意涵與引導問句，以溫柔的文字邀請抽卡者向內探索。Interpretation Text Placeholder — a warm, contemplative message unique to this card, inviting the reader to reflect inward.</span>
    </p>
    <p class="card-message" id="interpretMessage">
      「<span class="placeholder-text">牌卡金句 Card Message Placeholder</span>」
    </p>
    <div style="margin-top:2rem;display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="shareCard()" class="btn-outline" style="font-size:0.82rem;padding:0.5rem 1.4rem;">分享這張卡</button>
      <a href="/articles/" class="btn-outline" style="font-size:0.82rem;padding:0.5rem 1.4rem;">閱讀相關文章</a>
    </div>
  </div>

</section>

