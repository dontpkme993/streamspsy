---
layout: base.njk
title: 聲音與著作｜溪水邊 Stream Side
description: 溪水邊 Stream Side 聲音與著作 — Podcast 節目與出版著作一覽。
activeNav: media
---

<!-- ══════════════ PAGE HERO ══════════════ -->
<div class="page-hero">
  <p style="font-size:0.8rem;letter-spacing:0.18em;color:var(--straw);margin-bottom:0.5rem;text-transform:uppercase;">Sound & Works</p>
  <h1>聲音與著作</h1>
  <p>用聲音說故事，用文字留下溫度。</p>
</div>

<!-- ══════════════ PODCAST SECTION ══════════════ -->
<section class="py-section" aria-labelledby="podcast-heading">
  <div class="content-max">
    <p style="font-size:0.8rem;letter-spacing:0.18em;color:var(--straw);margin-bottom:0.5rem;text-transform:uppercase;">Podcast</p>
    <h2 class="section-title" id="podcast-heading" style="margin-bottom:0.5rem;">聲音節目</h2>
    <p style="color:rgba(67,52,48,0.6);font-size:0.9rem;margin-bottom:3rem;">每一集，帶你走進生活裡那些值得慢下來的時刻。</p>

    {% if podcast.episodes.length %}

      <!-- ── 最新集數 NEW ── -->
      <div style="margin-bottom:3rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
          <h3 style="font-size:0.9rem;color:var(--oak);font-weight:700;letter-spacing:0.08em;">最新集數</h3>
          <span style="background:#2d9e6b;color:white;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;padding:0.2rem 0.55rem;border-radius:2rem;">NEW</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:0;">
          {% for ep in podcast.episodes %}{% if loop.index <= 3 %}
            <article class="podcast-item">
              <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;">
                {% if ep.image %}
                  <img src="{{ ep.image }}" alt="{{ ep.title }}" style="width:56px;height:56px;border-radius:0.5rem;object-fit:cover;flex-shrink:0;">
                {% else %}
                  <div style="background:var(--sprout);width:56px;height:56px;border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">🎙️</div>
                {% endif %}
                <div>
                  <h4 style="font-size:1rem;color:var(--oak);line-height:1.5;margin-bottom:0.25rem;">{{ ep.title }}</h4>
                  <p style="font-size:0.75rem;color:rgba(67,52,48,0.45);">{{ ep.date | dateDisplay }}{% if ep.duration %} · {{ ep.duration }}{% endif %}</p>
                </div>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:1.25rem;align-items:flex-start;">
                {% if ep.embedUrl %}
                  <div style="flex:1;min-width:260px;border-radius:0.75rem;overflow:hidden;">
                    <iframe src="{{ ep.embedUrl }}" width="100%" style="aspect-ratio:1;max-height:480px;display:block;" frameborder="0" scrolling="no" loading="lazy"></iframe>
                  </div>
                {% endif %}
                {% if ep.summary %}
                  <div style="flex:1;min-width:260px;background:var(--rice);border-radius:0.75rem;padding:1.25rem;">
                    <p style="font-size:0.85rem;color:rgba(67,52,48,0.72);line-height:1.9;">{{ ep.summary | striptags | truncate(300) }}</p>
                    <a href="{{ ep.embedUrl or ep.link }}" target="_blank" rel="noopener" style="display:inline-block;margin-top:1rem;font-size:0.78rem;color:var(--straw);font-weight:600;">前往平台完整收聽 →</a>
                  </div>
                {% endif %}
              </div>
            </article>
          {% endif %}{% endfor %}
        </div>
      </div>

      <!-- ── 精選推薦 HOT ── -->
      {% set featuredList = podcast.featured %}
      {% if featuredList.length %}
        <div style="margin-bottom:3rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
            <h3 style="font-size:0.9rem;color:var(--oak);font-weight:700;letter-spacing:0.08em;">精選推薦</h3>
            <span style="background:#c0392b;color:white;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;padding:0.2rem 0.55rem;border-radius:2rem;">HOT</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:0;">
            {% for ep in featuredList %}{% if loop.index <= 3 %}
              <article class="podcast-item">
                <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;">
                  {% if ep.image %}
                    <img src="{{ ep.image }}" alt="{{ ep.title }}" style="width:56px;height:56px;border-radius:0.5rem;object-fit:cover;flex-shrink:0;">
                  {% else %}
                    <div style="background:var(--sprout);width:56px;height:56px;border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">🎙️</div>
                  {% endif %}
                  <div>
                    <h4 style="font-size:1rem;color:var(--oak);line-height:1.5;margin-bottom:0.25rem;">{{ ep.title }}</h4>
                    <p style="font-size:0.75rem;color:rgba(67,52,48,0.45);">{{ ep.date | dateDisplay }}{% if ep.duration %} · {{ ep.duration }}{% endif %}</p>
                  </div>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:1.25rem;align-items:flex-start;">
                  {% if ep.embedUrl %}
                    <div style="flex:1;min-width:260px;border-radius:0.75rem;overflow:hidden;">
                      <iframe src="{{ ep.embedUrl }}" width="100%" style="aspect-ratio:1;max-height:480px;display:block;" frameborder="0" scrolling="no" loading="lazy"></iframe>
                    </div>
                  {% endif %}
                  {% if ep.summary %}
                    <div style="flex:1;min-width:260px;background:var(--rice);border-radius:0.75rem;padding:1.25rem;">
                      <p style="font-size:0.85rem;color:rgba(67,52,48,0.72);line-height:1.9;">{{ ep.summary | striptags | truncate(300) }}</p>
                      <a href="{{ ep.embedUrl or ep.link }}" target="_blank" rel="noopener" style="display:inline-block;margin-top:1rem;font-size:0.78rem;color:var(--straw);font-weight:600;">前往平台完整收聽 →</a>
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endif %}{% endfor %}
          </div>
        </div>
      {% endif %}

      <!-- ── 全部集數 ── -->
      <div>
        <h3 style="font-size:0.9rem;color:var(--oak);font-weight:700;letter-spacing:0.08em;margin-bottom:1.5rem;">全部集數</h3>
        <div id="podcast-list" style="display:flex;flex-direction:column;gap:0;">
          {% for ep in podcast.episodes %}
            <article class="podcast-item" {% if loop.index > 4 %}style="display:none;"{% endif %}>
              <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;">
                {% if ep.image %}
                  <img src="{{ ep.image }}" alt="{{ ep.title }}" style="width:56px;height:56px;border-radius:0.5rem;object-fit:cover;flex-shrink:0;">
                {% else %}
                  <div style="background:var(--sprout);width:56px;height:56px;border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">🎙️</div>
                {% endif %}
                <div style="flex:1;">
                  <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
                    <h4 style="font-size:1rem;color:var(--oak);line-height:1.5;">{{ ep.title }}</h4>
                    {% if loop.index <= 3 %}<span style="background:#2d9e6b;color:white;font-size:0.65rem;font-weight:700;letter-spacing:0.08em;padding:0.15rem 0.45rem;border-radius:2rem;flex-shrink:0;">NEW</span>{% endif %}
                    {% if ep.featured %}<span style="background:#c0392b;color:white;font-size:0.65rem;font-weight:700;letter-spacing:0.08em;padding:0.15rem 0.45rem;border-radius:2rem;flex-shrink:0;">HOT</span>{% endif %}
                  </div>
                  <p style="font-size:0.75rem;color:rgba(67,52,48,0.45);">{{ ep.date | dateDisplay }}{% if ep.duration %} · {{ ep.duration }}{% endif %}</p>
                </div>
              </div>
              {% if ep.summary %}
                <p style="font-size:0.82rem;color:rgba(67,52,48,0.6);line-height:1.8;margin-bottom:0.75rem;">{{ ep.summary | striptags | truncate(120) }}</p>
              {% endif %}
              <a href="{{ ep.embedUrl or ep.link }}" target="_blank" rel="noopener" style="font-size:0.78rem;color:var(--straw);font-weight:600;">收聽 →</a>
            </article>
          {% endfor %}
        </div>

        {% if podcast.episodes.length > 4 %}
          <div style="text-align:center;margin-top:2.5rem;">
            <button id="podcast-load-more" class="btn-outline" onclick="loadMoreEpisodes()">顯示更多集數</button>
            <p id="podcast-count" style="font-size:0.78rem;color:rgba(67,52,48,0.4);margin-top:0.75rem;">顯示 4 / {{ podcast.episodes.length }} 集</p>
          </div>
        {% endif %}

        <script>
          var podcastShown = 4;
          var podcastTotal = {{ podcast.episodes.length }};
          var podcastStep = 4;
          function loadMoreEpisodes() {
            var next = podcastShown + podcastStep;
            var items = document.querySelectorAll('#podcast-list .podcast-item');
            for (var i = podcastShown; i < next && i < items.length; i++) {
              items[i].style.display = '';
            }
            podcastShown = Math.min(next, podcastTotal);
            document.getElementById('podcast-count').textContent = '顯示 ' + podcastShown + ' / ' + podcastTotal + ' 集';
            if (podcastShown >= podcastTotal) {
              document.getElementById('podcast-load-more').style.display = 'none';
              document.getElementById('podcast-count').textContent = '已顯示全部 ' + podcastTotal + ' 集';
            }
          }
        </script>
      </div>

    {% else %}
      <!-- Placeholder -->
      <article class="podcast-item">
        <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;">
          <div style="background:var(--sprout);width:56px;height:56px;border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">🎙️</div>
          <div>
            <h4 style="font-size:1rem;color:var(--oak);line-height:1.5;margin-bottom:0.25rem;"><span class="placeholder-text">Podcast 集數標題 Placeholder</span></h4>
            <p style="font-size:0.75rem;color:rgba(67,52,48,0.45);">2026年 · 約30分鐘</p>
          </div>
        </div>
        <div class="podcast-player-placeholder" aria-label="音頻播放器佔位符"><span>🎵</span><span>Podcast 播放器 Placeholder</span></div>
      </article>
    {% endif %}

  </div>
</section>

<div class="divider" style="margin:0 1.5rem;"></div>

